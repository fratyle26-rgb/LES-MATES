# Environment: development, staging, production
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=les_mates

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
RBAC_SERVICE_URL=http://localhost:3002
ORG_SERVICE_URL=http://localhost:3003
FINANCE_SERVICE_URL=http://localhost:3004

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api
VITE_AUTH_SERVICE=http://localhost:3001
VITE_FINANCE_SERVICE=http://localhost:3004

# API Gateway (if applicable)
API_GATEWAY_PORT=3000
API_GATEWAY_HEALTH_CHECK_INTERVAL=30000

# Logging
LOG_LEVEL=info
